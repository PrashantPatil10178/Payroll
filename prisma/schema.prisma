// Prisma schema for Better Auth
// learn more: https://better-auth.com/docs/concepts/database

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

// NOTE: When using mysql or sqlserver, uncomment the //@db.Text annotations in model Account below
// Further reading:
// https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  @@index([name])
}

model User {
  id             String        @id
  name           String //@db.Text
  email          String
  emailVerified  Boolean       @default(false)
  image          String? //@db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
  sessions       Session[]
  accounts       Account[]
  posts          Post[]
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  role           Role          @default(TEACHER)
  auditLogs      AuditLog[]
  memberships    UserOrganization[]
  teacherProfile Teacher?

  @@unique([email])
  @@index([organizationId])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String? //@db.Text
  userAgent String? //@db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String //@db.Text
  providerId            String //@db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String? //@db.Text
  refreshToken          String? //@db.Text
  idToken               String? //@db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String? //@db.Text
  password              String? //@db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String //@db.Text
  value      String //@db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Organization {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  status    OrganizationStatus @default(ACTIVE)
  ownerId   String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  users        User[]
  memberships  UserOrganization[]
  teachers     Teacher[]
  sessions     FacultySession[]
  payrolls     Payroll[]
  auditLogs    AuditLog[]
  invites      OrgInvite[]

  @@map("organization")
}

model OrgInvite {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           Role      @default(MANAGER)
  token          String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
  @@map("org_invite")
}

model UserOrganization {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           Role     @default(TEACHER)
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@map("user_organization")
}

model Teacher {
  id              String        @id @default(cuid())
  organizationId  String
  teacherCode     String
  fullName        String
  roleTitle       String?
  email           String?
  mobile          String?
  status          TeacherStatus @default(ACTIVE)
  memberType      MemberType    @default(TEACHER)
  specialization  String?
  avatar          String?
  joinedAt        DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Bank / tax details (for payroll transfer)
  bankAccountNumber String?
  bankIfsc          String?
  bankName          String?
  panNumber         String?
  upiId             String?
  paymentQrCode     String?

  // Portal login
  userId           String?   @unique
  inviteToken      String?   @unique
  inviteEmail      String?
  inviteExpiresAt  DateTime?

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?                @relation(fields: [userId], references: [id])
  payoutConfig TeacherPayoutConfig?
  sessions     FacultySession[]
  payrolls     Payroll[]

  @@unique([organizationId, teacherCode])
  @@index([organizationId, status])
  @@map("teacher")
}

model TeacherPayoutConfig {
  id                String   @id @default(cuid())
  teacherId         String   @unique
  liveRate          Decimal  @db.Decimal(12, 2)
  liveRateUnit      RateUnit @default(PER_HOUR)
  recordingRate     Decimal  @db.Decimal(12, 2)
  recordingRateUnit RateUnit @default(PER_HOUR)
  youtubeRate       Decimal  @db.Decimal(12, 2)
  youtubeRateUnit   RateUnit @default(PER_HOUR)
  doubtRate         Decimal? @db.Decimal(12, 2)
  doubtRateUnit     RateUnit @default(PER_HOUR)
  webinarRate       Decimal? @db.Decimal(12, 2)
  webinarRateUnit   RateUnit @default(PER_HOUR)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_payout_config")
}

model FacultySession {
  id              String        @id @default(cuid())
  organizationId  String
  teacherId       String
  sessionType     SessionType
  title           String
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  amount          Decimal       @db.Decimal(12, 2)
  status          SessionStatus @default(APPROVED)
  remarks         String?
  attachments     String[]      @default([])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teacher      Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([organizationId, teacherId, date])
  @@map("faculty_session")
}

model Payroll {
  id              String        @id @default(cuid())
  organizationId  String
  teacherId       String
  month           Int
  year            Int
  totalAmount     Decimal       @db.Decimal(12, 2)
  liveAmount      Decimal       @default(0) @db.Decimal(12, 2)
  recordingAmount Decimal       @default(0) @db.Decimal(12, 2)
  youtubeAmount   Decimal       @default(0) @db.Decimal(12, 2)
  otherAmount     Decimal       @default(0) @db.Decimal(12, 2)
  totalMinutes    Int           @default(0)
  sessionCount    Int           @default(0)
  status          PayrollStatus @default(DRAFT)
  payslipKey      String?

  // Adjustments & net pay
  bonusAmount     Decimal       @default(0) @db.Decimal(12, 2)
  deductionAmount Decimal       @default(0) @db.Decimal(12, 2)
  tdsAmount       Decimal       @default(0) @db.Decimal(12, 2)
  netAmount       Decimal       @default(0) @db.Decimal(12, 2)
  adjustmentNote  String?

  // Payment tracking
  paymentMethod    PaymentMethod?
  paymentReference String?

  generatedAt     DateTime      @default(now())
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teacher      Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([organizationId, teacherId, month, year])
  @@index([organizationId, year, month])
  @@map("payroll")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entity         String
  entityId       String
  oldValue       Json?
  newValue       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("audit_log")
}

enum Role {
  SUPER_ADMIN
  ORG_OWNER
  MANAGER
  TEACHER
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SessionType {
  LIVE_CLASS
  RECORDING
  YOUTUBE
  DOUBT_SOLVING
  WEBINAR
}

enum SessionStatus {
  DRAFT
  APPROVED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  GENERATED
  PAID
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  UPI
  CASH
  CHEQUE
  OTHER
}

enum RateUnit {
  PER_HOUR
  PER_SESSION
}

enum MemberType {
  TEACHER
  FREELANCER
}
