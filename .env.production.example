# ─── Required — set these in your deploy platform's environment variables ───

# Better Auth
BETTER_AUTH_SECRET="generate-a-random-64-char-string"   # openssl rand -base64 48
# BETTER_AUTH_URL is derived from APP_URL; set it explicitly if your platform needs it
# BETTER_AUTH_URL="https://your-app.railway.app"

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# MinIO / S3-compatible object storage
MINIO_ENDPOINT="your-minio-host.example.com"   # no https://, just the hostname
MINIO_PORT=443
MINIO_USE_SSL="true"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_BUCKET="efms"

# Public app URL (used for invite links, payslip PDFs, etc.)
APP_URL="https://your-app.railway.app"

# ─── Optional OAuth (remove if not using GitHub login) ───
# BETTER_AUTH_GITHUB_CLIENT_ID="your-github-client-id"
# BETTER_AUTH_GITHUB_CLIENT_SECRET="your-github-client-secret"
